generator client {
    provider = "prisma-client"
    output   = "../generated"
}

datasource db {
    provider = "postgresql"
}

// Enum
enum RoleType {
    ADMIN
    MANAGER
    AGENT
    CUSTOMER
}

enum UserStatus {
    ACTIVE
    SUSPENDED
    BANNED
}

// Models
model User {
    id        String     @id @default(uuid())
    email     String     @unique
    password  String
    name      String
    status    UserStatus @default(ACTIVE)
    roleId    String
    role      Role       @relation(fields: [roleId], references: [id])
    createdAt DateTime   @default(now())
    updatedAt DateTime   @updatedAt

    @@map("users")
}

model Role {
    id    String   @id @default(uuid())
    name  RoleType @unique
    users User[]
}
